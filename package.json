{
    "name": "vesperr",
    "version": "0.3.0",
    "description": "Professional WhatsApp Bot with Production-Grade Architecture - Baileys 7.x Compatible",
    "main": "index.js",
    "type": "module",
    "scripts": {
        "start": "node index.js",
        "dev": "NODE_ENV=development node --watch index.js",
        "start:gc": "node --expose-gc index.js",
        "start:cluster": "CLUSTER_MODE=true node index.js",
        "pm2": "pm2 start ecosystem.config.cjs",
        "pm2:stop": "pm2 stop vesperr",
        "pm2:restart": "pm2 restart vesperr",
        "pm2:logs": "pm2 logs vesperr",
        "test": "node --test",
        "lint": "eslint .",
        "format": "prettier --write ."
    },
    "keywords": [
        "whatsapp",
        "bot",
        "baileys",
        "whatsapp-bot",
        "vesperr",
        "wa-bot",
        "automation"
    ],
    "author": "MidknightMantra",
    "license": "MIT",
    "engines": {
        "node": ">=18.0.0"
    },
    "dependencies": {
        "@hapi/boom": "^10.0.1",
        "@types/node": "^25.0.0",
        "@whiskeysockets/baileys": "^7.0.0-rc.9",
        "axios": "^1.13.2",
        "cheerio": "^1.1.2",
        "crypto-js": "^4.2.0",
        "dotenv": "^17.2.3",
        "express": "^5.2.1",
        "file-type": "^21.1.1",
        "fluent-ffmpeg": "^2.1.3",
        "form-data": "^4.0.5",
        "lru-cache": "^11.2.4",
        "mime-types": "^3.0.2",
        "node-cache": "^5.1.2",
        "node-fetch": "^3.3.2",
        "node-webpmux": "^3.2.1",
        "pino": "^10.1.0",
        "qrcode-terminal": "^0.12.0",
        "sharp": "^0.34.5",
        "typescript": "^5.9.3",
        "xss": "^1.0.15",
        "yt-search": "^2.13.1"
    },
    "devDependencies": {
        "eslint": "^9.39.1",
        "nodemon": "^3.1.11",
        "pino-pretty": "^13.1.3",
        "prettier": "^3.7.4"
    },
    "optionalDependencies": {
        "@sentry/node": "^10.30.0"
    },
    "repository": {
        "type": "git",
        "url": "https://github.com/MidknightMantra/Vesperr"
    },
    "bugs": {
        "url": "https://github.com/MidknightMantra/Vesperr/issues"
    },
    "homepage": "https://github.com/MidknightMantra/Vesperr#readme"
}
